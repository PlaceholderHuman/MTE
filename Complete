# --- Core Functions ---

def fermi_dirac(E, ef, temp):
    #The f(E;T) function
    exponent = (E - ef) / (boltz * temp)
    if exponent > 400: return 0.0  #can cause overflow, so we return 0 for large exponent
    return 1.0 / (np.exp(exponent) + 1.0)

def get_mu_min(E, ef, phi_eff, h_omega):
    barrier = ef + phi_eff
    total_energy = E + h_omega
    
    if total_energy <= barrier:
        print("total<barrier")
    val = np.sqrt(barrier / total_energy)
    return val

def integrand_numerator(E, ef, phi_eff, h_omega, temp):
    #numerator for mte photo
    f_initial = fermi_dirac(E, ef, temp)
    f_final_inv = 1.0 - fermi_dirac(E + h_omega, ef, temp)
    mu = get_mu_min(E, ef, phi_eff, h_omega)
    geo_term = (2/3) - mu + (mu**3 / 3)
    
    return f_initial * f_final_inv * (E + h_omega) * geo_term

def integrand_denominator(E, ef, phi_eff, h_omega, temp):
    #denominator for mte photo
    f_initial = fermi_dirac(E, ef, temp)
    f_final_inv = 1.0 - fermi_dirac(E + h_omega, ef, temp)
    mu = get_mu_min(E, ef, phi_eff, h_omega)
    #the mu term becomes one and the geometric result is 0 which multiplies everything
    geo_term = 1.0 - mu
    result = f_initial * f_final_inv * geo_term
    return max(0.0, result)


def int_potential(x):
    # np.exp overflows around x = 709. 
    # For large x, use the mathematical asymptotic limit.
    if x > 700:
        return (x**2) / 2.0 + (np.pi**2) / 6.0
    return -sp.spence(1 + np.exp(x))
#Needs to be negative specnce as the condition for return is negative, and everywhere else would be canceled out



