#calculate all below
for n, temp in enumerate(T_array):
    mterld.append(boltz*temp)
    # Iterate through the 3 photon energies
    for index, hbar_omega in enumerate(photon_energies):
        jrld[index].append(A*(temp**2)*np.exp(-(phi/(boltz*temp))))
        qejrld[index].append(c2[index]*((temp/t0)**2)*np.exp(-(phi/(boltz*temp))))

        #CALCULATING MTE photo process below
        E_min = fermi + phi - hbar_omega
        #separate into numerator and denominator
        num, _ = quad(integrand_numerator, E_min, np.inf, args=(fermi, phi, hbar_omega, temp))
        den, _ = quad(integrand_denominator, E_min, np.inf, args=(fermi, phi, hbar_omega, temp))
        
        if den <= 0:
            mte_photo = 0.0 
        else:
            mte_photo = num / den
        mte[index].append(mte_photo)

        #POSSIBLE ERROR THAT hbar omega < phi
        #CALCULATING J PHOTO BELOW
        num = int_potential(((boltz*temp)**(-1))*(hbar_omega-phi))
        denom = int_potential(((boltz*temp)**(-1))*fermi)
        j[index].append(newc1[index]*num/denom)
        qejphoto[index].append(c1[index]*num/denom)
        final[index].append((j[index][n]*mte[index][n]+jrld[index][n]*mterld[n])/(j[index][n]+jrld[index][n]))



