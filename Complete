def comp_fermi_initial(E, ef, temp):
    return fermi_dirac(E, ef, temp)

def comp_fermi_final_inv(E, ef, h_omega, temp):
    return 1.0 - fermi_dirac(E + h_omega, ef, temp)

def comp_geometric(E, ef, phi_eff, h_omega):
    mu = get_mu_min(E, ef, phi_eff, h_omega)
    return (2/3) - mu + (mu**3 / 3)

def comp_denominator(E, ef, phi_eff, h_omega, temp):
    mu = get_mu_min(E, ef, phi_eff, h_omega)
    geo_term = 1.0 - mu
    
    return  geo_term
